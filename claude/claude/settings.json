  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "."
      ],
      "denyWrite": [
        "/run/media",
        "~/"
      ],
      "denyRead": [
        "/run/media",
        "~/"
      ],
      "allowRead": [
        "~/.config/zsh",
        "."
      ]
    },
