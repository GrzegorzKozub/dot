  "model": "opus[1m]",
  "enabledPlugins": {
    "apsis-katie@apsis": true,
    "apsis-mcp@apsis": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "apsis": {
      "source": {
        "source": "github",
        "repo": "efficy-sa/apsis-claude-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "."
      ],
      "denyWrite": [
        "~/",
        "/run/media"
      ],
      "denyRead": [
        "~/",
        "/run/media"
      ],
      "allowRead": [
        "."
      ]
    },
    "excludedCommands": [
      "aws *",
      "docker *",
      "gh *",
      "git *",
      "podman *",
      "ssh *"
    ]
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true
}

